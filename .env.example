# Copy to .env and adjust. Never commit .env.

# Database — Postgres connection string (e.g. Supabase Session pooler). Used by Docker.
# postgresql+psycopg://postgres.<ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# Leave blank to fall back to local SQLite (non-docker dev only).
DATABASE_URL=

# LLM provider: "gemini" (cloud, default) or "ollama" (local).
LLM_PROVIDER=gemini
# Optional model override. Defaults: gemini -> gemini-2.5-flash, ollama -> qwen2.5
LLM_MODEL=gemini-2.5-flash

# Gemini (cloud) — required when LLM_PROVIDER=gemini
GEMINI_API_KEY=

# Ollama (local) — only when LLM_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434

# SMTP — outbound email for outreach
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Public URL of the opt-in form (or your Google Form) — appended to LinkedIn post drafts
OPTIN_URL=http://localhost:8000/optin

# Google Form opt-in import (free, no hosting). Publish the responses Sheet to the
# web as CSV (File → Share → Publish to web → CSV) and paste that link here.
# When set, Setu imports opted-in candidates from it (button + hourly auto-import).
GOOGLE_FORM_CSV_URL=

# Background scheduler — auto-draft LinkedIn posts on a cadence (inbound engine)
SCHEDULE_POSTS=false
POST_INTERVAL_DAYS=3

# LinkedIn auto-posting (Phase 8, optional) — leave blank to draft + copy manually
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:xxxx
LINKEDIN_AUTOPOST=false        # false = approve-before-publish (default)
# LINKEDIN_API_VERSION=202405  # Posts API version header (override if needed)
